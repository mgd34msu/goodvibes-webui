  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Browser operator surface for the GoodVibes daemon.",
  "scripts": {
    "dev": "vite",
    "build": "bun run presentation:check && bun run config-schema:check && bun run internal-identifiers:check && tsc --noEmit && vite build",
    "ci": "bun run test && bun run typecheck && bun run build",
    "presentation:generate": "bun run scripts/generate-presentation-tokens.ts",
    "presentation:check": "bun run scripts/generate-presentation-tokens.ts --check",
