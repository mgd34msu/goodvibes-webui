    "config-schema:check": "bun run scripts/generate-config-schema.ts --check",
    "internal-identifiers:check": "bun run scripts/internal-identifier-check.ts",
    "preview": "vite preview --host 127.0.0.1 --port 3423 --strictPort",
    "test": "bun test --isolate",
    "test:live": "bun run scripts/live-daemon-smoke.ts",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "e2e:phone": "playwright test --project=phone",
    "e2e:desktop": "playwright test --project=desktop",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sdk:link": "bun run scripts/sdk-dev.ts link",
    "sdk:status": "bun run scripts/sdk-dev.ts status",
    "sdk:restore": "bun run scripts/sdk-dev.ts restore",
    "release:gate": "bun run scripts/release-gate.ts",
    "gate": "bun run test && bun run typecheck && bun run build && bun run release:gate",
    "prepublishOnly": "bun run release:gate"
  },
