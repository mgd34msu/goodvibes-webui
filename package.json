{
  "name": "goodvibes-webui",
  "private": true,
  "version": "0.1.39",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "description": "Browser operator surface for the GoodVibes daemon.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "ci": "bun run test && bun run typecheck && bun run build",
    "preview": "vite preview --host 127.0.0.1 --port 3423 --strictPort",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@pellux/goodvibes-sdk": "0.33.30",
    "@tanstack/react-query": "^5.100.11",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "10.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "happy-dom": "^20.10.6",
    "prettier": "3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "^8.0.13"
  }
}
